# 인파 백업 설정 — backup.env 로 복사한 뒤 값 채우고 chmod 600 backup.env
# Neon 대시보드 > Connection Details 의 접속 문자열 (?sslmode=require 포함 권장)
DATABASE_URL="postgres://USER:PASSWORD@HOST/neondb?sslmode=require"
# 백업 보관 폴더 (서버 내 경로)
BACKUP_DIR="/home/USER/inpa-backups"
# 암호문 파일: openssl rand -base64 32 > ~/.inpa-backup-pass && chmod 600 ~/.inpa-backup-pass
# ★ 이 암호문을 잃으면 백업을 영영 못 풉니다. 비밀번호 관리자에 사본 보관하세요.
GPG_PASSPHRASE_FILE="/home/USER/.inpa-backup-pass"
# 보존 일수(기본 30)
RETENTION_DAYS=30
# 복원 시에만: 스크래치 DB URL (운영 URL 금지)
# TARGET_DATABASE_URL="postgres://.../scratch"
