# === 인파 백엔드 환경변수 (.env로 복사해서 사용) ===
# 시크릿 — 운영은 반드시 교체
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*

# DB (운영 MariaDB 예시 — 로컬은 SQLite 자동 사용)
# DATABASE_URL=mysql://user:pass@host:3306/inpa

# 인증 토큰 TTL
EMAIL_VERIFY_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TIMEOUT=3600

# 이메일 발송 (로컬=콘솔 출력 / 운영=Resend SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@inpa.local
# 운영 예시:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxx
# EMAIL_USE_SSL=True

# 프론트엔드 (이메일 링크 생성용)
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Claude API (Phase 1.1)
# ANTHROPIC_API_KEY=sk-ant-xxx
