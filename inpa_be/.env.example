# === 인파 백엔드 환경변수 (.env로 복사해서 사용) ===
# 시크릿 — 운영은 반드시 교체
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*

# DB (운영 PostgreSQL 예시 = Neon — 로컬은 SQLite 자동 사용)
# DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/inpa?sslmode=require

# 인증 토큰 TTL
EMAIL_VERIFY_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TIMEOUT=3600

# 이메일 발송 (로컬=콘솔 출력 / 운영=Resend SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@inpa.local
# 운영 예시:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxx
# EMAIL_USE_SSL=True

# 프론트엔드 (이메일 링크 생성용)
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Claude API (Phase 1.1 — 증권 OCR 파싱·담보 정규화)
# 비어 있으면 OCR 업로드가 503(OCR_UNAVAILABLE) 반환 — 키 주입 시 활성화. 하드코딩 금지.
ANTHROPIC_API_KEY=

# 구글 연동 (소셜 로그인 + 캘린더) — 전부 비어 있으면 기능 숨김(무해).
# 로그인은 CLIENT_ID만, 캘린더는 SECRET+REDIRECT_URI까지 필요. CLIENT_SECRET은 ★시크릿(Render 전용).
GOOGLE_OAUTH_ENABLED=False
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 캘린더 콜백(구글 콘솔 redirect URI와 정확히 일치, 끝 슬래시 포함):
# 예) https://<render-be>/api/v1/auth/google/calendar/callback/
GOOGLE_OAUTH_REDIRECT_URI=
